# =============================================================================
# Obscura Trading Engine — Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.
# =============================================================================

# --- Bybit WebSocket ---
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BYBIT_KLINE_INTERVAL=5

# --- Bybit REST (cold start historical fetch) ---
BYBIT_REST_URL=https://api.bybit.com
BYBIT_REST_INTERVAL=5

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_STREAM_KEY=market:kline:5m
REDIS_CONSUMER_GROUP=engine-group
REDIS_STATE_PREFIX=state

# --- Redis ZSET (Hard Boundary data bridge between Rust and Python) ---
REDIS_ZSET_PREFIX=market:kline:5m
REDIS_ZSET_MAX_SIZE=8640

# --- QuestDB ---
QUESTDB_ILP_HOST=questdb
QUESTDB_ILP_PORT=9009
QUESTDB_HTTP_URL=http://questdb:9000

# --- Telegram Alerts ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
TELEGRAM_RATE_LIMIT_SECONDS=300

# --- Python Engine ---
ENGINE_LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Confidence Thresholds ---
SCORE_FULL_SIZE_THRESHOLD=90
SCORE_SCALED_SIZE_THRESHOLD=70
